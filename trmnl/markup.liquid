<div class="layout familyboard">
  <main class="familyboard__main">
    {% for day in days %}
      <section class="day">
        <header class="day__header">
          <span class="day__label">{{ day.label }}</span>
          <span class="day__date">{{ day.date }}</span>
        </header>

        <div class="day__events">
          {% for event in day.events %}
            <div class="event">
              <span class="event__time">
                {% if event.allDay %}
                  Journée
                {% else %}
                  {{ event.displayTime }}
                {% endif %}
              </span>

              <span class="event__title">{{ event.title }}</span>
            </div>
          {% endfor %}
        </div>
      </section>
    {% endfor %}
  </main>

  <aside class="familyboard__sidebar">
    <section class="panel panel--ongoing">
      <div class="panel__title">En cours</div>

      {% if ongoing.size > 0 %}
        {% for event in ongoing %}
          <div class="ongoing-event">
            <div class="ongoing-event__title">{{ event.title }}</div>

            <div class="ongoing-event__meta">
              {{ event.progress }} · fin {{ event.ends }}
            </div>
          </div>
        {% endfor %}
      {% else %}
        <div class="panel__empty">Aucun événement long</div>
      {% endif %}
    </section>

    <section class="panel panel--next-week">
      <div class="panel__title">Semaine prochaine</div>

      {% if nextWeek.highlights.size > 0 %}
        {% for event in nextWeek.highlights %}
          <div class="highlight">
            <span class="highlight__day">{{ event.day }}</span>
            <span class="highlight__title">{{ event.title }}</span>
          </div>
        {% endfor %}
      {% else %}
        <div class="panel__empty">Rien à signaler</div>
      {% endif %}
    </section>
  </aside>
</div>

<div class="title_bar">
  <span class="title">FamilyBoard</span>
</div>
